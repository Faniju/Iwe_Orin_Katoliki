<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="YorubaCatholicHymn.FavoritesPage"
             Title="Favorites">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Clear All"
                     Command="{Binding ClearAllFavoritesCommand}" />
    </ContentPage.ToolbarItems>

    <CollectionView ItemsSource="{Binding Favorites}">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border Background="LightGray" Padding="10" Margin="5">
                    <Border.GestureRecognizers>
                        <!-- Tap to open hymn detail -->
                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenHymnDetailCommand}"
                                              CommandParameter="{Binding}" />
                    </Border.GestureRecognizers>
                    <StackLayout>
                        <Label Text="{Binding Number}" FontAttributes="Bold" TextColor="DarkRed" />
                        <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="Medium" />
                        <Label Text="{Binding Snippet}" FontSize="Small" TextColor="Gray" 
                               LineBreakMode="TailTruncation" MaxLines="1" FontAttributes="Italic"/>
                        <Label Text="{Binding Author}" FontSize="Small" TextColor="DarkGreen" />

                        <!-- Remove button -->
                        <Button Text="Remove"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveFavoriteCommand}"
                                CommandParameter="{Binding}" />
                    </StackLayout>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>
