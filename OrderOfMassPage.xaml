                  FontAttributes="Bold"
                  TextColor="Black" />
                        <Span Text="✠ "
                  FontSize="20"
                  FontAttributes="Bold"
                  TextColor="Red" />
                        <Span Text="àti Ọmọ, àti Ẹmí Mímó̩. Àmín."
                  FontSize="18"
                  FontAttributes="Bold"
                  TextColor="Black" />
                    </FormattedString>
